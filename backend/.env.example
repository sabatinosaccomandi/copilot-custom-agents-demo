# Copy this file to .env and fill in real values.
# .env must NEVER be committed to version control (it is listed in .gitignore).

# REQUIRED – generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-secret-min-32-chars

# Optional – defaults to a local SQLite file when not set
DATABASE_URL=sqlite:///demo.db

# Set to "true" only in local development, never in production
FLASK_DEBUG=false
